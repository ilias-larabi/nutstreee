{% comment %}
  NUTSTREE — Premium Sticky Add to Cart Snippet (Or & Cuir)
  Injecté depuis theme.liquid uniquement sur les pages produit.
{% endcomment %}

{{- 'sticky-add-to-cart.css' | asset_url | stylesheet_tag -}}

<div class="nt-sticky-atc" aria-live="polite" aria-label="{{ 'products.product.add_to_cart' | t }}" hidden>
  <div class="nt-sticky-atc__inner">

    {%- if product.featured_image -%}
      <div class="nt-sticky-atc__thumbnail-wrapper">
        <img 
          src="{{ product.featured_image | image_url: width: 100 }}" 
          alt="{{ product.title | escape }}" 
          class="nt-sticky-atc__thumbnail"
          loading="lazy"
          width="50"
          height="50"
        >
      </div>
    {%- endif -%}

    <div class="nt-sticky-atc__info">
      <span class="nt-sticky-atc__title">{{ product.title | escape }}</span>
      <span class="nt-sticky-atc__price" id="nt-sticky-price">
        {{- product.selected_or_first_available_variant.price | money -}}
      </span>
    </div>

    {%- unless product.has_only_default_variant -%}
      <div class="nt-sticky-atc__variants">
        {%- if product.variants.size <= 3 -%}
          <div class="nt-sticky-atc__pills">
            {%- for variant in product.variants -%}
              <button 
                type="button" 
                class="nt-sticky-atc__pill {% if variant.id == product.selected_or_first_available_variant.id %}is-active{% endif %}"
                data-variant-id="{{ variant.id }}"
                {% unless variant.available %}disabled{% endunless %}
              >
                {{ variant.title | escape }}
              </button>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="nt-sticky-atc__dropdown">
            <select class="nt-sticky-atc__select" id="nt-sticky-select">
              {%- for variant in product.variants -%}
                <option 
                  value="{{ variant.id }}" 
                  {% if variant.id == product.selected_or_first_available_variant.id %}selected="selected"{% endif %}
                  {% unless variant.available %}disabled="disabled"{% endunless %}
                >
                  {{ variant.title }}
                </option>
              {%- endfor -%}
            </select>
          </div>
        {%- endif -%}
      </div>
    {%- endunless -%}

    <button
      class="nt-sticky-atc__btn"
      type="button"
      aria-label="{{ 'products.product.add_to_cart' | t }}"
      id="sticky-atc-btn"
      {% unless product.selected_or_first_available_variant.available %}
        disabled
        data-sold-out
      {% endunless %}
    >
      <span class="nt-sticky-atc__btn-text">
        {%- if product.selected_or_first_available_variant.available -%}
          AJOUTER AU PANIER
        {%- else -%}
          ÉPUISÉ
        {%- endif -%}
      </span>
    </button>

  </div>
</div>

<script>
  // Reveal the bar (hidden by default to avoid flash before JS takes control)
  document.querySelector('.nt-sticky-atc')?.removeAttribute('hidden');
</script>

<script src="{{ 'sticky-add-to-cart.js' | asset_url }}" defer></script>
