{%- style -%}
  .nt-cats-page {
    background-color: #F5F0E6; /* --cream */
    padding: 3rem 0 5rem;
  }
  .nt-cats-page__title {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 600;
    color: #3B4F2A; /* --olive */
    text-align: center;
    margin-bottom: 2rem;
  }
  .nt-cats__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  @media (min-width: 600px) {
    .nt-cats__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
  }
  @media (min-width: 990px) {
    .nt-cats__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop | default: 3 }}, 1fr);
      gap: 1.25rem;
    }
  }
  .nt-cat-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border-radius: 16px;
    height: 110px;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    padding: 12px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  @media (min-width: 768px) {
    .nt-cat-card {
      height: 150px;
    }
  }
  .nt-cat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 30px -14px rgba(0,0,0,.3);
  }
  .nt-cat-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(200deg, transparent 25%, rgba(0,0,0,.42));
    pointer-events: none;
    z-index: 1;
  }
  .nt-cat-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    z-index: 0;
  }
  .nt-cat-card:hover .nt-cat-card__img {
    transform: scale(1.08);
  }
  .nt-cat-card__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .nt-grad-0 { background: linear-gradient(135deg, #6B8A4A, #3B4F2A); }
  .nt-grad-1 { background: linear-gradient(135deg, #D9A94A, #C5A55A); }
  .nt-grad-2 { background: linear-gradient(135deg, #8B5A32, #5C3521); }
  .nt-grad-3 { background: linear-gradient(135deg, #D08055, #C0622A); }
  .nt-grad-4 { background: linear-gradient(135deg, #A68A55, #7A6339); }
  .nt-grad-5 { background: linear-gradient(135deg, #8B3E18, #5C2A0F); }

  .nt-cat-card__icon {
    position: relative;
    z-index: 2;
    color: rgba(255,255,255,.88);
    width: 20px;
    height: 20px;
    margin-bottom: 5px;
    flex-shrink: 0;
  }
  .nt-cat-card__name {
    position: relative;
    z-index: 2;
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 13px;
    line-height: 1.3;
    text-shadow: 0 1px 4px rgba(0,0,0,.25);
  }
  .nt-cat-card__count {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    background: rgba(255,255,255,.2);
    backdrop-filter: blur(4px);
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    padding: 3px 7px;
    border-radius: 20px;
  }
{%- endstyle -%}

<div class="nt-cats-page">
<div class="page-width">
  <h1 class="nt-cats-page__title">
    {{ section.settings.title }}
  </h1>
  {%- liquid
    case section.settings.sort
      when 'products_high', 'products_low'
        assign collections = collections | sort: 'all_products_count'
      when 'date', 'date_reversed'
        assign collections = collections | sort: 'published_at'
    endcase

    if section.settings.sort == 'products_high' or section.settings.sort == 'date_reversed' or section.settings.sort == 'alphabetical_reversed'
      assign collections = collections | reverse
    endif

    assign moduloResult = 28 | modulo: section.settings.columns_desktop
    assign paginate_by = 30
    if moduloResult == 0
      assign paginate_by = 28
    endif
  -%}
  {%- paginate collections by paginate_by -%}
    {%- liquid
      assign icon_handles = 'fruit,sec,olive,amande,pistache,noix,cajou,noisette|miel,honey,api|chocolat,choco,cacao|confit,cerise,abricot|epice,cannelle,cumin,safran,curcuma|cadeau,coffret,gift,plateau|datte,medjool,ajwa,sukkari|amlou,the,tisane' | split: '|'
      assign icon_names   = 'leaf|honey|chocolate|fruit|spice|gift|dates|leaf' | split: '|'
    -%}
    <ul class="nt-cats__grid" role="list">
      {%- for collection in collections -%}
        {%- assign grad_index = forloop.index0 | modulo: 6 -%}
        {%- assign icon_id = 'leaf' -%}
        {%- for pattern_group in icon_handles -%}
          {%- assign patterns = pattern_group | split: ',' -%}
          {%- for pat in patterns -%}
            {%- if collection.handle contains pat -%}
              {%- assign icon_id = icon_names[forloop.parentloop.index0] -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
        <li>
          <a href="{{ collection.url }}" class="nt-cat-card">
            <div class="nt-cat-card__bg nt-grad-{{ grad_index }}"></div>
            {%- if collection.image -%}
              <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" class="nt-cat-card__img" loading="lazy" width="600" height="300">
            {%- elsif collection.products.first.featured_image -%}
              <img src="{{ collection.products.first.featured_image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" class="nt-cat-card__img" loading="lazy" width="600" height="300">
            {%- endif -%}
            <div class="nt-cat-card__count">{{ collection.all_products_count }} produits</div>
            <div class="nt-cat-card__icon" aria-hidden="true">
              {%- case icon_id -%}
                {%- when 'honey' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10c4-4 12-4 16 0M6 14c3-3 9-3 12 0M9 18c1.5-1.5 4.5-1.5 6 0"/></svg>
                {%- when 'chocolate' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18M9 5v14M15 5v14"/></svg>
                {%- when 'fruit' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="7"/><path d="M12 6V3m-3 3c0-1.7 1.3-3 3-3s3 1.3 3 3"/></svg>
                {%- when 'spice' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v10M8 7l4-4 4 4M6 13h12l-1.5 8h-9z"/></svg>
                {%- when 'gift' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12v9H4v-9M2 7h20v5H2zM12 7V3M12 7c-2 0-3.5-2-2-4 2-1 2.5 1.5 2 4zM12 7c2 0 3.5-2 2-4-2-1-2.5 1.5-2 4z"/></svg>
                {%- when 'dates' -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="14" rx="5" ry="7"/><path d="M12 7V3M9 5c0 0 1-2 3-2s3 2 3 2"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8 6 6 9 6 13a6 6 0 0012 0c0-4-2-7-6-11z"/><path d="M12 22v-9"/></svg>
              {%- endcase -%}
            </div>
            <span class="nt-cat-card__name">{{ collection.title }}</span>
          </a>
        </li>
      {%- endfor -%}
    </ul>
    {% render 'pagination', paginate: paginate %}
  {%- endpaginate -%}
</div>
</div>
{% schema %}
{
  "name": "t:sections.main-list-collections.name",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:sections.main-list-collections.settings.title.label",
      "default": "t:sections.main-list-collections.settings.title.default"
    },
    {
      "type": "select",
      "id": "sort",
      "options": [
        {
          "value": "alphabetical",
          "label": "t:sections.main-list-collections.settings.sort.options__1.label"
        },
        {
          "value": "alphabetical_reversed",
          "label": "t:sections.main-list-collections.settings.sort.options__2.label"
        },
        {
          "value": "date_reversed",
          "label": "t:sections.main-list-collections.settings.sort.options__3.label"
        },
        {
          "value": "date",
          "label": "t:sections.main-list-collections.settings.sort.options__4.label"
        },
        {
          "value": "products_high",
          "label": "t:sections.main-list-collections.settings.sort.options__5.label"
        },
        {
          "value": "products_low",
          "label": "t:sections.main-list-collections.settings.sort.options__6.label"
        }
      ],
      "default": "alphabetical",
      "label": "t:sections.main-list-collections.settings.sort.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.main-list-collections.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.main-list-collections.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.main-list-collections.settings.image_ratio.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.main-list-collections.settings.image_ratio.label"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "t:sections.main-list-collections.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        {
          "value": "1",
          "label": "t:sections.main-list-collections.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.main-list-collections.settings.columns_mobile.options__2.label"
        }
      ],
      "default": "2",
      "label": "t:sections.main-list-collections.settings.columns_mobile.label"
    }
  ]
}
{% endschema %}
