{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .nt-collection-banner {
    background-color: #3B4F2A; /* Olive foncé */
    color: #F5F0E6; /* Crème */
    padding: 60px 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .nt-collection-banner__title {
    font-family: 'Playfair Display', serif;
    font-size: 3.5rem;
    font-weight: 600;
    margin: 0 0 16px 0;
    color: #F5F0E6;
  }
  .nt-collection-banner__desc {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
    color: rgba(245, 240, 230, 0.85);
  }
  .nt-collection-banner__accent {
    color: #C5A55A; /* Gold */
    font-style: italic;
  }
  @media screen and (max-width: 749px) {
    .nt-collection-banner {
      padding: 40px 16px;
    }
    .nt-collection-banner__title {
      font-size: 2.5rem;
    }
  }
{%- endstyle -%}

<div class="nt-collection-banner">
  <div class="page-width">
    <h1 class="nt-collection-banner__title">
      {{- collection.title | escape -}}
    </h1>

    {%- if section.settings.show_collection_description and collection.description != blank -%}
      <div class="nt-collection-banner__desc rte">
        {{ collection.description }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Bannière Collection",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "Afficher la description"
    }
  ]
}
{% endschema %}
