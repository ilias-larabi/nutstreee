{% comment %}
  NUTSTREE — Reviews Section
  3 cartes d'avis clients, fond vert olive, carousel mobile
{% endcomment %}

{%- style -%}
  .nt-reviews-{{ section.id }} {
    --c-bg:       {{ section.settings.color_background | default: '#EEF0E8' }};
    --c-card:     {{ section.settings.color_card       | default: '#FFFFFF' }};
    --c-primary:  {{ section.settings.color_primary    | default: '#3B4F2A' }};
    --c-accent:   {{ section.settings.color_accent     | default: '#C0622A' }};
    --c-gold:     {{ section.settings.color_gold       | default: '#C5A55A' }};
    --c-text:     {{ section.settings.color_text       | default: '#1E1E1E' }};
    --c-muted:    {{ section.settings.color_muted      | default: '#6B6B5C' }};
    --ff-head: 'Playfair Display', serif;
    --ff-body: 'Inter', sans-serif;

    background-color: var(--c-bg);
    padding: 5rem 0;
    overflow: hidden;
  }

  .nt-reviews__header {
    text-align: center;
    padding: 0 1.25rem;
    margin-bottom: 3rem;
  }

  .nt-reviews__eyebrow {
    font-family: var(--ff-body);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--c-accent);
    display: block;
    margin-bottom: 0.75rem;
  }

  .nt-reviews__title {
    font-family: var(--ff-head);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 700;
    color: var(--c-primary);
    margin: 0;
  }

  /* ── Carousel ── */
  .nt-reviews__track {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.5rem 1.25rem 1.5rem;
    scroll-snap-type: x mandatory;
  }

  .nt-reviews__track::-webkit-scrollbar { display: none; }

  @media (min-width: 750px) {
    .nt-reviews__track {
      overflow: visible;
      display: grid;
      grid-template-columns: repeat({{ section.blocks.size | at_most: 3 }}, 1fr);
      gap: 1.5rem;
      padding: 0.5rem 3rem 1.5rem;
    }
  }

  @media (min-width: 990px) {
    .nt-reviews__track {
      padding: 0.5rem 6% 1.5rem;
    }
  }

  /* ── Card ── */
  .nt-review-card {
    flex: 0 0 85%;
    scroll-snap-align: start;
    background: var(--c-card);
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: 0 2px 20px rgba(59,79,42,.06), 0 1px 4px rgba(0,0,0,.04);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  @media (min-width: 750px) {
    .nt-review-card {
      flex: unset;
    }
  }

  .nt-review-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 35px rgba(59,79,42,.1), 0 4px 12px rgba(0,0,0,.06);
  }

  /* ── Stars ── */
  .nt-review-card__stars {
    display: flex;
    gap: 3px;
    color: var(--c-gold);
  }

  .nt-review-card__stars svg { width: 18px; height: 18px; }

  /* ── Quote icon ── */
  .nt-review-card__quote {
    color: var(--c-primary);
    opacity: 0.12;
    align-self: flex-end;
    margin-top: -0.5rem;
  }

  .nt-review-card__quote svg { width: 36px; height: 36px; }

  /* ── Text ── */
  .nt-review-card__text {
    font-family: var(--ff-body);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--c-text);
    flex: 1;
    font-style: italic;
  }

  /* ── Author ── */
  .nt-review-card__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(59,79,42,.08);
  }

  .nt-review-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--c-primary), #5A7A40);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--ff-head);
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
    text-transform: uppercase;
  }

  .nt-review-card__author-info {}

  .nt-review-card__name {
    font-family: var(--ff-body);
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--c-text);
    display: block;
  }

  .nt-review-card__location {
    font-family: var(--ff-body);
    font-size: 0.78rem;
    color: var(--c-muted);
    display: block;
  }

  /* ── Google badge on card ── */
  .nt-review-card__source {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--ff-body);
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--c-muted);
    margin-top: 0.25rem;
  }

  .nt-review-card__source svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  /* ── Distinct avatar colors (cycles per index) ── */
  .nt-avatar-0 { background: linear-gradient(135deg, #3B4F2A, #5A7A40); }
  .nt-avatar-1 { background: linear-gradient(135deg, #C0622A, #8B3E18); }
  .nt-avatar-2 { background: linear-gradient(135deg, #C5A55A, #8B6914); }
  .nt-avatar-3 { background: linear-gradient(135deg, #5A7A40, #3B4F2A); }
  .nt-avatar-4 { background: linear-gradient(135deg, #8B3E18, #C0622A); }
  .nt-avatar-5 { background: linear-gradient(135deg, #4A6080, #2C3D55); }

  /* ── Google CTA block ── */
  .nt-reviews__google-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    padding: 0 1.25rem;
  }

  .nt-reviews__google-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.5rem;
    background: #fff;
    color: #3c4043;
    font-family: var(--ff-body);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 100px;
    border: 1.5px solid rgba(0,0,0,.12);
    box-shadow: 0 2px 8px rgba(0,0,0,.08);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .nt-reviews__google-btn:hover {
    box-shadow: 0 6px 18px rgba(0,0,0,.15);
    transform: translateY(-2px);
  }

  .nt-reviews__google-btn svg { flex-shrink: 0; }

  .nt-reviews__google-note {
    font-family: var(--ff-body);
    font-size: 0.75rem;
    color: var(--c-muted);
    text-align: center;
  }

  /* ── Overall rating ── */
  .nt-reviews__overall {
    text-align: center;
    margin-top: 2.5rem;
    padding: 0 1.25rem;
  }

  .nt-reviews__overall-stars {
    display: inline-flex;
    gap: 4px;
    color: var(--c-gold);
    margin-bottom: 0.4rem;
  }

  .nt-reviews__overall-stars svg { width: 22px; height: 22px; }

  .nt-reviews__overall-text {
    font-family: var(--ff-body);
    font-size: 0.85rem;
    color: var(--c-muted);
    display: block;
  }
{%- endstyle -%}

<div class="nt-reviews-{{ section.id }}">
  <div class="nt-reviews__header">
    {%- if section.settings.eyebrow != blank -%}
      <span class="nt-reviews__eyebrow">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="nt-reviews__title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}
  </div>

  <div class="nt-reviews__track">
    {%- for block in section.blocks -%}
      {%- if block.type == 'review' -%}
        {%- assign avatar_class = 'nt-avatar-' | append: forloop.index0 | append: '' -%}
        {%- assign avatar_index = forloop.index0 | modulo: 6 -%}
        <div class="nt-review-card" {{ block.shopify_attributes }}>
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <div class="nt-review-card__stars">
              {%- assign stars = block.settings.rating | default: 5 -%}
              {%- for i in (1..stars) -%}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- endfor -%}
            </div>
            <div class="nt-review-card__quote">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
            </div>
          </div>

          {%- if block.settings.text != blank -%}
            <p class="nt-review-card__text">{{ block.settings.text | escape }}</p>
          {%- endif -%}

          <div class="nt-review-card__author">
            <div class="nt-review-card__avatar nt-avatar-{{ avatar_index }}">{{ block.settings.name | truncate: 1, '' }}</div>
            <div class="nt-review-card__author-info">
              <span class="nt-review-card__name">{{ block.settings.name | default: 'Client' | escape }}</span>
              {%- if block.settings.location != blank -%}
                <span class="nt-review-card__location">{{ block.settings.location | escape }}</span>
              {%- endif -%}
              {%- if block.settings.is_google -%}
                <span class="nt-review-card__source">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                  </svg>
                  Avis Google vérifié
                </span>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.google_maps_url != blank -%}
    <div class="nt-reviews__google-cta">
      <a href="{{ section.settings.google_maps_url | escape }}" target="_blank" rel="noopener" class="nt-reviews__google-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Laisser un avis Google
      </a>
      <span class="nt-reviews__google-note">Votre avis aide d'autres clients à nous découvrir ❤️</span>
    </div>
  {%- endif -%}

  <div class="nt-reviews__overall">
    <div class="nt-reviews__overall-stars">
      {%- for i in (1..5) -%}
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      {%- endfor -%}
    </div>
    <span class="nt-reviews__overall-text">{{ section.settings.overall_text | default: 'Note moyenne : 5/5 — 200+ avis clients vérifiés' }}</span>
  </div>
</div>

{% schema %}
{
  "name": "Avis Clients",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Surtitre",
      "default": "Ce que disent nos clients"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Ils ont adoré Nutstree"
    },
    {
