{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;500;600&display=swap');

  .awwwards-hero-{{ section.id }} {
    /* Variables locales pour garantir l'indépendance de la section */
    --color-bg: #F5F0E6;
    --color-text: #2C2C2C;
    --color-gold: #C5A55A;
    --font-heading: 'Playfair Display', serif;
    --font-body: 'Inter', sans-serif;

    background-color: var(--color-bg);
    color: var(--color-text);
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    
    /* 1. COMPOSITION ASYMÉTRIQUE ET GRANDIOSE */
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    padding: 6rem 1.5rem;
  }

  @media screen and (min-width: 990px) {
    .awwwards-hero-{{ section.id }} {
      grid-template-columns: 1fr 1fr;
      padding: 0 5%;
    }
  }

  /* Filigrane géant en arrière-plan */
  .awwwards-hero__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-heading);
    font-size: clamp(8rem, 25vw, 40rem);
    font-weight: 900;
    opacity: 0.04;
    white-space: nowrap;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }

  /* Colonne de gauche : Contenu Textuel */
  .awwwards-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  .awwwards-hero__eyebrow {
    font-family: var(--font-body);
    font-size: clamp(0.875rem, 1vw + 0.5rem, 1rem);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text);
    opacity: 0.7;
    margin-bottom: 2rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .awwwards-hero__eyebrow::before {
    content: '';
    display: block;
    width: 60px;
    height: 1px;
    background-color: currentColor;
  }

  .awwwards-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(3.5rem, 6vw + 1rem, 7rem);
    line-height: 1.05;
    margin: 0 0 3rem 0;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .awwwards-hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 1.2rem 3.5rem;
    background-color: var(--color-text);
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 2px;
    /* Animations 60 FPS du bouton */
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.4s ease;
  }

  .awwwards-hero__cta:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 30px rgba(44, 44, 44, 0.2);
    background-color: #000000;
  }

  /* 3. DÉTAILS PREMIUM : Focus accessible doré */
  .awwwards-hero__cta:focus-visible {
    outline: 2px solid #C5A55A;
    outline-offset: 4px;
  }

  /* Colonne de droite : Médias & Produit */
  .awwwards-hero__media {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    perspective: 1000px; /* Profondeur 3D */
  }

  /* Wrapper pour isoler l'animation de lévitation du hover CSS */
  .awwwards-hero__image-wrapper {
    /* 2. L'EFFET "SACHET 3D" : ANIMATION DE LÉVITATION */
    animation: float-subtle 5s ease-in-out infinite;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  @keyframes float-subtle {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }

  .awwwards-hero__image {
    /* 2. L'EFFET "SACHET 3D" : TAILLE GÉANTE */
    max-width: clamp(450px, 45vw, 850px);
    max-height: 85vh;
    width: 100%;
    height: auto;
    object-fit: contain;
    
    /* 2. L'EFFET "SACHET 3D" : INCRUSTATION PARFAITE */
    mix-blend-mode: multiply;
    
    /* 2. L'EFFET "SACHET 3D" : DOUBLE DROP-SHADOW RÉALISTE */
    filter: drop-shadow(0 28px 40px rgba(0,0,0,0.10)) drop-shadow(0 8px 12px rgba(0,0,0,0.06));
    
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), filter 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    /* Optimisation matérielle pour garantir les 60 FPS lors de l'animation complexe */
    will-change: transform, filter;
  }

  /* 2. L'EFFET "SACHET 3D" : EFFET AU SURVOL */
  .awwwards-hero__image:hover {
    transform: scale(1.025);
    /* L'ombre s'élargit pour simuler l'approche vers l'écran */
    filter: drop-shadow(0 40px 50px rgba(0,0,0,0.15)) drop-shadow(0 15px 20px rgba(0,0,0,0.08));
    cursor: pointer;
  }

  /* 3. DÉTAILS PREMIUM : Indicateur de Scroll */
  .awwwards-hero__scroll {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 100px;
    background: linear-gradient(to bottom, transparent, rgba(44, 44, 44, 0.3));
    z-index: 3;
    overflow: hidden;
  }

  @keyframes scroll-dot-awwwards {
    0% { transform: translateY(-100%); opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { transform: translateY(100px); opacity: 0; }
  }

  .awwwards-hero__scroll-dot {
    position: absolute;
    top: 0;
    left: -2px;
    width: 5px;
    height: 5px;
    background-color: var(--color-gold);
    border-radius: 50%;
    animation: scroll-dot-awwwards 2s cubic-bezier(0.77, 0, 0.175, 1) infinite;
  }
{%- endstyle -%}

<div class="awwwards-hero-{{ section.id }}">
  
  {%- if section.settings.watermark != blank -%}
    <div class="awwwards-hero__watermark" aria-hidden="true">
      {{ section.settings.watermark }}
    </div>
  {%- endif -%}

  <!-- 1. COMPOSITION : Colonne de Gauche -->
  <div class="awwwards-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="awwwards-hero__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h1 class="awwwards-hero__title">{{ section.settings.title | newline_to_br }}</h1>
    {%- endif -%}

    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_link | default: '#' }}" class="awwwards-hero__cta">
        {{ section.settings.btn_label }}
      </a>
    {%- endif -%}
  </div>

  <!-- 1. COMPOSITION : Colonne de Droite (Le Sachet) -->
  <div class="awwwards-hero__media">
    <div class="awwwards-hero__image-wrapper">
      {%- if section.settings.image_link != blank -%}
        <a href="{{ section.settings.image_link }}" aria-label="Voir la catégorie">
      {%- endif -%}

      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1600 | image_tag:
          loading: 'eager',
          class: 'awwwards-hero__image',
          sizes: '(min-width: 990px) 50vw, 100vw',
          widths: '400, 600, 800, 1000, 1200, 1600'
        }}
      {%- else -%}
        <!-- Fallback visuel dans l'éditeur -->
        {{ 'product-1' | placeholder_svg_tag: 'awwwards-hero__image' }}
      {%- endif -%}

      {%- if section.settings.image_link != blank -%}
        </a>
      {%- endif -%}
    </div>
  </div>

  <!-- 3. DÉTAILS PREMIUM : Indicateur de Scroll -->
  <div class="awwwards-hero__scroll" aria-hidden="true">
    <div class="awwwards-hero__scroll-dot"></div>
  </div>

</div>

{% schema %}
{
  "name": "Hero Awwwards 3D",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "watermark",
      "label": "Filigrane d'arrière-plan",
      "default": "NUTSTREE"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Surtitre",
      "default": "Création Artisanale"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre principal",
      "default": "L'Excellence\nà l'état brut"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Bouton Call-to-Action",
      "default": "Découvrir le produit"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Lien du bouton"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image du Sachet (Doypack)",
      "info": "Idéalement photographié sur un fond clair/blanc très uni. Le CSS magique s'assurera du détourage et du réalisme des ombres."
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Lien du sachet",
      "info": "Rend le sachet cliquable pour rediriger (ex: catégories)."
    }
  ],
  "presets": [
    {
      "name": "Hero Awwwards 3D",
      "category": "Image"
    }
  ]
}
{% endschema %}
