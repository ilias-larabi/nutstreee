{% comment %}
  NUTSTREE — Hero Section (Mobile-First Redesign)
  Layout: Text + Image côte à côte dès le premier écran mobile
{% endcomment %}

{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,900;1,600&family=Inter:wght@400;500;600&display=swap');

  .nt-hero-{{ section.id }} {
    --c-bg:       {{ section.settings.color_background | default: '#F5F0E6' }};
    --c-primary:  {{ section.settings.color_primary    | default: '#3B4F2A' }};
    --c-accent:   {{ section.settings.color_secondary  | default: '#C0622A' }};
    --c-gold:     {{ section.settings.color_gold       | default: '#C5A55A' }};
    --c-text:     {{ section.settings.color_text       | default: '#1E1E1E' }};
    --c-muted:    {{ section.settings.color_muted      | default: '#6B6B5C' }};
    --c-surface:  #FFFFFF;
    --ff-head: 'Playfair Display', serif;
    --ff-body: 'Inter', sans-serif;

    background-color: var(--c-bg);
    position: relative;
    overflow: hidden;
    min-height: 100svh;
  }

  /* ── Background texture ── */
  .nt-hero-{{ section.id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 70% 20%, rgba(197,165,90,.08) 0%, transparent 60%),
      radial-gradient(circle at 10% 80%, rgba(74,93,58,.06) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Watermark ── */
  .nt-hero__watermark {
    position: absolute;
    bottom: -2rem;
    right: -1rem;
    font-family: var(--ff-head);
    font-size: clamp(5rem, 25vw, 14rem);
    font-weight: 900;
    color: var(--c-primary);
    opacity: 0.025;
    line-height: 1;
    user-select: none;
    pointer-events: none;
    z-index: 0;
    white-space: nowrap;
  }

  /* ── Layout ── */
  .nt-hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto;
    min-height: 100svh;
    align-items: center;
    padding: 5.5rem 1.25rem 3rem 1.25rem;
    gap: 0;
  }

  @media (min-width: 750px) {
    .nt-hero__grid {
      grid-template-columns: 1fr 1fr;
      padding: 4rem 5% 4rem 5%;
      gap: 2rem;
    }
  }

  @media (min-width: 990px) {
    .nt-hero__grid {
      grid-template-columns: 55% 45%;
      gap: 4rem;
      padding: 0 6% 0 6%;
    }
  }

  /* ── Text column ── */
  .nt-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    opacity: 0;
    animation: ntHeroFadeUp 0.8s ease-out 0.1s forwards;
  }

  /* ── Eyebrow ── */
  .nt-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--ff-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--c-accent);
    margin-bottom: 1rem;
  }

  .nt-hero__eyebrow-line {
    display: block;
    width: 28px;
    height: 2px;
    background: var(--c-accent);
    border-radius: 2px;
  }

  /* ── Title ── */
  .nt-hero__title {
    font-family: var(--ff-head);
    font-size: clamp(1.9rem, 5.5vw, 4.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--c-primary);
    margin: 0 0 1rem 0;
    word-break: break-word;
  }

  .nt-hero__title em {
    font-style: italic;
    color: var(--c-accent);
  }

  /* ── Description ── */
  .nt-hero__desc {
    font-family: var(--ff-body);
    font-size: clamp(0.9rem, 2vw, 1.1rem);
    line-height: 1.7;
    color: var(--c-muted);
    margin: 0 0 1.75rem 0;
    max-width: 38ch;
  }

  /* ── CTA buttons ── */
  .nt-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .nt-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.75rem;
    min-height: 48px;
    background: var(--c-accent);
    color: #fff;
    font-family: var(--ff-body);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 100px;
    border: 2px solid var(--c-accent);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    animation: ntPulse 3s ease-in-out 2s infinite;
  }

  @keyframes ntPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(192,98,42,.35); }
    50%       { box-shadow: 0 0 0 8px rgba(192,98,42,0); }
  }

  .nt-btn-primary:hover, .nt-btn-primary:active {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 12px 28px rgba(192,98,42,.35);
    animation: none;
  }

  .nt-btn-primary svg { transition: transform 0.25s ease; }
  .nt-btn-primary:hover svg { transform: translateX(4px); }

  .nt-btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    min-height: 48px;
    background: transparent;
    color: var(--c-primary);
    font-family: var(--ff-body);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 100px;
    border: 2px solid rgba(59,79,42,.25);
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .nt-btn-ghost:hover {
    border-color: var(--c-primary);
    background: var(--c-primary);
    color: #fff;
  }

  /* ── Social proof ── */
  .nt-hero__proof {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .nt-hero__stars {
    display: flex;
    gap: 2px;
  }

  .nt-hero__stars svg { color: var(--c-gold); }

  .nt-hero__proof-text {
    font-family: var(--ff-body);
    font-size: 0.82rem;
    color: var(--c-muted);
  }

  .nt-hero__proof-text strong {
    color: var(--c-text);
    font-weight: 600;
  }

  /* ── Visual column ── */
  .nt-hero__visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: ntHeroFadeScale 0.9s ease-out 0.3s forwards;
  }

  @keyframes ntHeroFadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes ntHeroFadeScale {
    from { opacity: 0; transform: scale(0.9); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* ── Decorative blob ── */
  .nt-hero__blob {
    position: absolute;
    width: clamp(140px, 35vw, 380px);
    height: clamp(140px, 35vw, 380px);
    background: radial-gradient(circle, rgba(197,165,90,.18) 0%, rgba(74,93,58,.1) 60%, transparent 100%);
    border-radius: 50%;
    z-index: 0;
  }

  /* ── Product image ── */
  .nt-hero__img-link { display: block; position: relative; z-index: 1; }

  .nt-hero__img {
    width: clamp(140px, 42vw, 480px);
    height: auto;
    object-fit: contain;
    filter:
      drop-shadow(0 20px 35px rgba(0,0,0,.13))
      drop-shadow(0 6px 12px rgba(74,93,58,.12));
    animation: ntFloat 6s ease-in-out infinite;
    display: block;
  }

  @keyframes ntFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%       { transform: translateY(-12px) rotate(.8deg); }
  }

  .nt-hero__img-link:hover .nt-hero__img {
    filter:
      drop-shadow(0 28px 45px rgba(0,0,0,.18))
      drop-shadow(0 10px 20px rgba(74,93,58,.18));
  }

  /* ── Badge flottant ── */
  .nt-hero__badge {
    position: absolute;
    top: 10%;
    right: -5%;
    background: var(--c-primary);
    color: #fff;
    font-family: var(--ff-body);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.5rem 0.85rem;
    border-radius: 100px;
    box-shadow: 0 6px 20px rgba(59,79,42,.3);
    white-space: nowrap;
    z-index: 2;
    animation: ntBadgePop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 0.8s both;
  }

  @keyframes ntBadgePop {
    from { opacity: 0; transform: scale(0.5); }
    to   { opacity: 1; transform: scale(1); }
  }

  /* ── Market Tag (prix/poids façon étiquette de marché) ── */
  .nt-hero__tag {
    position: absolute;
    bottom: -16px;
    left: -10px;
    background: #FEFCF8;
    border: 1.5px dashed var(--c-gold);
    border-radius: 8px;
    padding: 9px 14px 9px 18px;
    transform: rotate(-4deg);
    box-shadow: 0 10px 18px -10px rgba(0,0,0,.25);
    z-index: 3;
    animation: ntBadgePop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 1s both;
    white-space: nowrap;
  }
  .nt-hero__tag::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #DFDACC;
    box-shadow: inset 0 0 0 1.2px rgba(0,0,0,.12);
  }
  .nt-hero__tag-weight {
    font-family: var(--ff-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .03em;
    color: var(--c-muted);
    line-height: 1.2;
  }
  .nt-hero__tag-price {
    font-family: var(--ff-head);
    font-weight: 700;
    font-size: 16px;
    color: #8B3E18;
    line-height: 1.3;
  }

  /* ── Scroll indicator ── */
  .nt-hero__scroll {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    z-index: 2;
  }

  .nt-hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--c-primary), transparent);
    opacity: 0.4;
    animation: ntScrollLine 2s ease-in-out infinite;
  }

  @keyframes ntScrollLine {
    0%, 100% { transform: scaleY(1); opacity: 0.4; }
    50%       { transform: scaleY(0.5); opacity: 0.15; }
  }

  /* ── Mobile adjustments ── */
  @media (max-width: 749px) {
    .nt-hero__grid {
      grid-template-columns: 1fr 1fr;
      min-height: 100svh;
      align-items: center;
      padding: 5rem 1rem 3rem;
    }

    .nt-hero__desc {
      display: none;
    }

    .nt-hero__title {
      font-size: clamp(1.6rem, 7vw, 2.2rem);
    }

    .nt-hero__img {
      width: clamp(130px, 45vw, 220px);
    }

    .nt-hero__badge {
      font-size: 0.6rem;
      padding: 0.35rem 0.6rem;
      right: -8%;
      top: 5%;
    }

    .nt-btn-primary, .nt-btn-ghost {
      font-size: 0.85rem;
      padding: 0.75rem 1.2rem;
    }

    .nt-hero__proof-text { font-size: 0.75rem; }

    .nt-hero__scroll { display: none; }
  }
{%- endstyle -%}

<div class="nt-hero-{{ section.id }}">
  <div class="nt-hero__watermark" aria-hidden="true">{{ section.settings.watermark_text | default: 'Nutstree' }}</div>

  <div class="nt-hero__grid">

    {%- comment -%} ── TEXT COLUMN ── {%- endcomment -%}
    <div class="nt-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nt-hero__eyebrow">
          <span class="nt-hero__eyebrow-line"></span>
          {{ section.settings.eyebrow | escape }}
        </p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h1 class="nt-hero__title">{{ section.settings.title }}</h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="nt-hero__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      <div class="nt-hero__actions">
        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_link | default: '/collections/all' }}" class="nt-btn-primary" id="hero-cta-primary">
            {{ section.settings.btn_label | escape }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.btn2_label != blank -%}
          <a href="{{ section.settings.btn2_link | default: '/collections' }}" class="nt-btn-ghost" id="hero-cta-secondary">
            {{ section.settings.btn2_label | escape }}
          </a>
        {%- endif -%}
      </div>

      <div class="nt-hero__proof">
        <div class="nt-hero__stars" aria-label="5 étoiles">
          {%- for i in (1..5) -%}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {%- endfor -%}
        </div>
        <p class="nt-hero__proof-text">
          <strong>{{ section.settings.proof_count | default: '200+' }}</strong> {{ section.settings.proof_text | default: 'clients satisfaits au Maroc' }}
        </p>
      </div>
    </div>

    {%- comment -%} ── IMAGE COLUMN ── {%- endcomment -%}
    <div class="nt-hero__visual">
      <div class="nt-hero__blob"></div>

      {%- if section.settings.image_link != blank -%}
        <a href="{{ section.settings.image_link }}" class="nt-hero__img-link" aria-label="Voir nos produits">
      {%- else -%}
        <div class="nt-hero__img-link">
      {%- endif -%}

        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 900 | image_tag:
              class: 'nt-hero__img',
              loading: 'eager',
              alt: section.settings.image.alt | default: 'Produit Nutstree',
              widths: '200, 350, 500, 700, 900',
              sizes: '(max-width: 749px) 45vw, (max-width: 989px) 40vw, 420px'
          }}
        {%- else -%}
          <img src="{{ 'product-sachet.png' | asset_url }}" class="nt-hero__img" alt="Nutstree — Fruits secs artisanaux" loading="eager" width="900" height="900">
        {%- endif -%}

        {%- if section.settings.badge_text != blank -%}
          <span class="nt-hero__badge">{{ section.settings.badge_text | escape }}</span>
        {%- endif -%}

        {%- if section.settings.tag_weight != blank or section.settings.tag_price != blank -%}
          <div class="nt-hero__tag">
            {%- if section.settings.tag_weight != blank -%}
              <div class="nt-hero__tag-weight">{{ section.settings.tag_weight | escape }}</div>
            {%- endif -%}
            {%- if section.settings.tag_price != blank -%}
              <div class="nt-hero__tag-price">{{ section.settings.tag_price | escape }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}

      {%- if section.settings.image_link != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
    </div>

  </div>

  <div class="nt-hero__scroll" aria-hidden="true">
    <div class="nt-hero__scroll-line"></div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Premium Nutstree",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Surtitre",
      "default": "Fruits secs d'exception"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre principal (HTML limité)",
      "default": "Le meilleur de la nature, <em>torréfié</em> avec passion"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description (masquée sur mobile pour clarté)",
      "default": "Sélection artisanale, du producteur à votre table. Torréfié avec soin, livré frais au Maroc."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Bouton principal — Texte",
      "default": "Découvrir la boutique"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Bouton principal — Lien"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Bouton secondaire — Texte",
      "default": "Nos catégories"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Bouton secondaire — Lien"
    },
    {
      "type": "text",
      "id": "proof_count",
      "label": "Nombre de clients (preuve sociale)",
      "default": "200+"
    },
    {
      "type": "text",
      "id": "proof_text",
      "label": "Texte preuve sociale",
      "default": "clients satisfaits au Maroc"
    },
    {
      "type": "header",
      "content": "Image produit"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Photo produit (PNG sans fond recommandé)"
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Lien au clic sur l'image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge flottant",
      "default": "100% Artisanal"
    },
    {
      "type": "header",
      "content": "Étiquette prix (tag de marché)"
    },
    {
      "type": "text",
      "id": "tag_weight",
      "label": "Poids / variante (ex: 250g)",
      "default": "250g"
    },
    {
      "type": "text",
      "id": "tag_price",
      "label": "Prix (ex: 150 DH)",
      "default": "150 DH"
    },
    {
      "type": "text",
      "id": "watermark_text",
      "label": "Texte en filigrane",
      "default": "Nutstree"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Fond",
      "default": "#F5F0E6"
    },
    {
      "type": "color",
      "id": "color_primary",
      "label": "Primaire (Vert olive)",
      "default": "#3B4F2A"
    },
    {
      "type": "color",
      "id": "color_secondary",
      "label": "Accent (Terracotta)",
      "default": "#C0622A"
    },
    {
      "type": "color",
      "id": "color_gold",
      "label": "Doré (Étoiles)",
      "default": "#C5A55A"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Texte",
      "default": "#1E1E1E"
    },
    {
      "type": "color",
      "id": "color_muted",
      "label": "Texte secondaire",
      "default": "#6B6B5C"
    }
  ],
  "presets": [
    {
      "name": "Hero Premium Nutstree"
    }
  ]
}
{% endschema %}
