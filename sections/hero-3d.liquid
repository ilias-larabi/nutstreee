{% comment %}
  NUTSTREE — Hero Section (Premium Mockup Match)
  Layout: Background Image, Floating Card CTA with Leather button
{% endcomment %}

{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,900;1,600&family=Inter:wght@400;500;600&display=swap');

  .nt-hero-{{ section.id }} {
    --c-primary:  {{ section.settings.color_primary    | default: '#3B4F2A' }};
    --c-accent:   {{ section.settings.color_secondary  | default: '#C0622A' }};
    --c-gold:     {{ section.settings.color_gold       | default: '#C5A55A' }};
    --c-leather:  #3A2315;
    --c-text:     {{ section.settings.color_text       | default: '#1E1E1E' }};
    --ff-head: 'Playfair Display', serif;
    --ff-body: 'Inter', sans-serif;

    position: relative;
    overflow: hidden;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .nt-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .nt-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(4px) brightness(0.9);
  }

  .nt-hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(255,255,255,0.7) 0%, rgba(245,240,230,0.95) 70%, #F5F0E6 100%);
  }

  .nt-hero__grid {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    padding: 5rem 1.5rem 3rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  @media (min-width: 768px) {
    .nt-hero__grid {
      flex-direction: row;
      align-items: center;
      gap: 3rem;
    }
  }

  /* ── Text column ── */
  .nt-hero__content {
    display: flex;
    flex-direction: column;
    opacity: 0;
    animation: ntHeroFadeUp 0.8s ease-out forwards;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .nt-hero__content {
      flex: 1;
      margin-bottom: 0;
    }
  }

  .nt-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--ff-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--c-gold);
    margin-bottom: 0.5rem;
  }

  .nt-hero__eyebrow-line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--c-gold);
  }

  .nt-hero__title {
    font-family: var(--ff-head);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--c-leather);
    margin: 0;
  }

  .nt-hero__title em {
    font-style: italic;
    color: var(--c-leather);
  }

  /* ── Image & Card Container ── */
  .nt-hero__interactive {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    opacity: 0;
    animation: ntHeroFadeUp 0.8s ease-out 0.2s forwards;
  }

  @media (min-width: 768px) {
    .nt-hero__interactive {
      flex: 1;
    }
  }

  .nt-hero__product-img {
    width: 100%;
    max-width: 300px;
    height: auto;
    z-index: 2;
    transform: translateY(20px);
    margin-left: auto; /* Push to right based on mockup */
    filter: drop-shadow(0 15px 25px rgba(0,0,0,0.15));
  }

  /* ── Floating Card ── */
  .nt-hero__card {
    background: #FFFFFF;
    border-radius: 12px;
    padding: 1.5rem;
    width: 100%;
    max-width: 350px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    position: relative;
    z-index: 1;
    margin-top: -10px;
  }

  .nt-hero__variants {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .nt-hero__pill {
    border: 1px solid var(--c-gold);
    color: var(--c-leather);
    background: transparent;
    padding: 0.5rem 1.2rem;
    border-radius: 20px;
    font-family: var(--ff-body);
    font-size: 0.85rem;
    font-weight: 600;
  }

  .nt-hero__pill.is-active {
    background: rgba(197, 165, 90, 0.1);
  }

  .nt-hero__btn-wrapper {
    position: relative;
  }

  .nt-hero__btn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: var(--c-leather);
    color: #F5F0E6;
    padding: 1rem 1.5rem;
    border-radius: 30px;
    text-decoration: none;
    font-family: var(--ff-body);
    font-weight: 600;
    font-size: 0.95rem;
    box-shadow: inset 0 2px 4px rgba(255,255,255,0.1), 0 4px 15px rgba(58, 35, 21, 0.3);
    transition: all 0.3s ease;
  }

  .nt-hero__btn:hover {
    background-color: #2C1A10;
    transform: translateY(-2px);
  }

  .nt-hero__btn svg {
    color: var(--c-gold);
  }

  .nt-hero__price-badge {
    position: absolute;
    top: -15px;
    right: -10px;
    background: linear-gradient(135deg, #E5C158, #C5A55A);
    color: var(--c-leather);
    font-family: var(--ff-body);
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.4rem 0.8rem;
    border-radius: 20px;
    box-shadow: 0 4px 10px rgba(197, 165, 90, 0.4);
  }

  /* ── Social Proof ── */
  .nt-hero__proof {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    opacity: 0;
    animation: ntHeroFadeUp 0.8s ease-out 0.4s forwards;
    padding-left: 0.5rem;
  }

  .nt-hero__stars {
    color: var(--c-gold);
    display: flex;
  }

  .nt-hero__proof-text {
    font-family: var(--ff-body);
    font-size: 0.85rem;
    color: var(--c-text);
    margin: 0;
  }

  .nt-hero__stamp {
    position: absolute;
    bottom: -1rem;
    right: 0;
    width: 80px;
    opacity: 0.15;
  }

  @keyframes ntHeroFadeUp {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* Decorative pattern */
  .nt-hero-pattern {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100px;
    background-image: url('data:image/svg+xml;utf8,<svg width="40" height="40" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg"><path d="M20 0l20 20-20 20L0 20z" fill="%23C5A55A" fill-opacity="0.05"/></svg>');
    z-index: 0;
  }
{%- endstyle -%}

<div class="nt-hero-{{ section.id }}">
  
  <div class="nt-hero-bg">
    {%- if section.settings.bg_image != blank -%}
      {{ section.settings.bg_image | image_url: width: 1200 | image_tag: loading: 'eager' }}
    {%- else -%}
      <div style="background: #e9e5db; width: 100%; height: 100%;"></div>
    {%- endif -%}
  </div>

  <div class="nt-hero-pattern"></div>

  <div class="nt-hero__grid">

    {%- comment -%} ── TEXT COLUMN ── {%- endcomment -%}
    <div class="nt-hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nt-hero__eyebrow">
          <span class="nt-hero__eyebrow-line"></span>
          {{ section.settings.eyebrow | escape }}
        </p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h1 class="nt-hero__title">{{ section.settings.title }}</h1>
      {%- endif -%}
    </div>

    {%- comment -%} ── IMAGE & CARD COLUMN ── {%- endcomment -%}
    <div class="nt-hero__interactive">
      
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 600 | image_tag: class: 'nt-hero__product-img', loading: 'eager', alt: 'Produit Nutstree' }}
      {%- else -%}
         <div class="nt-hero__product-img" style="background:#3B4F2A; height:300px; width:200px; border-radius:10px;"></div>
      {%- endif -%}

      <div class="nt-hero__card">
        <div class="nt-hero__variants">
          <div class="nt-hero__pill is-active">250g</div>
          <div class="nt-hero__pill">500g</div>
        </div>

        <div class="nt-hero__btn-wrapper">
          <a href="{{ section.settings.btn_link | default: '/collections/all' }}" class="nt-hero__btn">
            <span>{{ section.settings.btn_label | escape }}</span>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <div class="nt-hero__price-badge">150 DH</div>
        </div>
      </div>

      <div class="nt-hero__proof">
        <div class="nt-hero__stars" aria-label="5 étoiles">
          {%- for i in (1..5) -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {%- endfor -%}
        </div>
        <p class="nt-hero__proof-text">
          <strong>{{ section.settings.proof_count | default: '200+' }}</strong> {{ section.settings.proof_text | default: 'clients satisfaits au Maroc' }}
        </p>
        
        <!-- Stamp SVG representation -->
        <svg class="nt-hero__stamp" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="48" fill="none" stroke="var(--c-leather)" stroke-width="1"/>
          <circle cx="50" cy="50" r="42" fill="none" stroke="var(--c-leather)" stroke-width="0.5"/>
          <text x="50" y="25" font-family="var(--ff-body)" font-size="10" font-weight="bold" fill="var(--c-leather)" text-anchor="middle" letter-spacing="2">NUTS TREE</text>
          <text x="50" y="85" font-family="var(--ff-body)" font-size="6" fill="var(--c-leather)" text-anchor="middle" letter-spacing="1">ESTD FINEST</text>
        </svg>
      </div>

    </div>

  </div>
</div>

{% schema %}
{
  "name": "Hero Premium Nutstree",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Surtitre",
      "default": "Fruits secs d'exception"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre principal (HTML limité)",
      "default": "Le meilleur de la nature, <em>torréfié</em> avec passion"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Bouton carte — Texte",
      "default": "Découvrir le sachet de 500g"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Bouton carte — Lien"
    },
    {
      "type": "text",
      "id": "proof_count",
      "label": "Nombre de clients (preuve sociale)",
      "default": "200+"
    },
    {
      "type": "text",
      "id": "proof_text",
      "label": "Texte preuve sociale",
      "default": "clients satisfaits au Maroc"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Image d'arrière-plan (ex: Riad)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Photo produit (PNG sans fond recommandé)"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "color_primary",
      "label": "Primaire (Vert olive)",
      "default": "#3B4F2A"
    },
    {
      "type": "color",
      "id": "color_secondary",
      "label": "Accent (Terracotta)",
      "default": "#C0622A"
    },
    {
      "type": "color",
      "id": "color_gold",
      "label": "Doré (Étoiles)",
      "default": "#C5A55A"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Texte",
      "default": "#1E1E1E"
    }
  ],
  "presets": [
    {
      "name": "Hero Premium Nutstree"
    }
  ]
}
{% endschema %}
