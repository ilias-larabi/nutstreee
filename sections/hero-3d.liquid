{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700;900&display=swap');

  .hero-3d-{{ section.id }} {
    /* Variables de marque */
    --color-primary: {{ section.settings.color_primary | default: '#4A5D3A' }};
    --color-secondary: {{ section.settings.color_secondary | default: '#B5651D' }};
    --color-background: {{ section.settings.color_background | default: '#F5F0E6' }};
    --color-surface: {{ section.settings.color_surface | default: '#FFFFFF' }};
    --color-gold: {{ section.settings.color_gold | default: '#C5A55A' }};
    --color-text: {{ section.settings.color_text | default: '#2C2C2C' }};
    --font-heading: 'Playfair Display', serif;
    --font-body: 'Inter', sans-serif;
    
    background-color: var(--color-background);
    color: var(--color-text);
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    padding: 6rem 1.5rem 4rem 1.5rem;
  }

  @media (min-width: 768px) {
    .hero-3d-{{ section.id }} {
      grid-template-columns: 1fr 1fr;
      padding: 0 5%;
    }
  }

  /* Filigrane géant */
  .hero-3d__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-heading);
    font-size: clamp(6rem, 20vw, 30rem);
    font-weight: 900;
    color: var(--color-text);
    opacity: 0.04;
    white-space: nowrap;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }

  /* Contenu textuel */
  .hero-3d__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding-right: clamp(1rem, 5vw, 4rem);
  }

  .hero-3d__eyebrow {
    font-family: var(--font-body);
    font-size: clamp(0.75rem, 1vw + 0.5rem, 1rem);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-secondary);
    margin-bottom: 1.5rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .hero-3d__eyebrow::before {
    content: '';
    display: block;
    width: 40px;
    height: 1px;
    background-color: var(--color-secondary);
  }

  .hero-3d__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw + 1rem, 5.5rem);
    line-height: 1.05;
    color: var(--color-primary);
    margin: 0 0 1.5rem 0;
    font-weight: 700;
  }

  .hero-3d__description {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw + 0.5rem, 1.25rem);
    line-height: 1.6;
    color: var(--color-text);
    opacity: 0.8;
    margin-bottom: 3rem;
    max-width: 90%;
  }

  /* Bouton Call to Action */
  .hero-3d__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 1rem 2.5rem;
    background-color: var(--color-primary);
    color: var(--color-surface);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 50px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    border: 1px solid var(--color-primary);
    cursor: pointer;
    overflow: hidden;
    position: relative;
  }

  .hero-3d__btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    transition: all 0.6s ease;
  }

  .hero-3d__btn:hover {
    background-color: var(--color-primary);
    color: var(--color-surface);
    transform: translateY(-4px);
    box-shadow: 0 15px 30px rgba(74, 93, 58, 0.25);
  }

  .hero-3d__btn:hover::before {
    left: 100%;
  }

  .hero-3d__btn:focus-visible {
    outline: 2px solid var(--color-gold);
    outline-offset: 4px;
  }

  .hero-3d__btn svg {
    margin-left: 0.75rem;
    transition: transform 0.3s ease;
  }

  .hero-3d__btn:hover svg {
    transform: translateX(6px);
  }

  /* Visuel Produit */
  .hero-3d__visual {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100%;
    margin-top: 4rem;
  }

  @media (min-width: 768px) {
    .hero-3d__visual {
      margin-top: 0;
    }
  }

  @keyframes float-subtle {
    0% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(1deg); }
    100% { transform: translateY(0px) rotate(0deg); }
  }

  .hero-3d__image-link {
    display: block;
    cursor: pointer;
  }

  .hero-3d__image {
    max-width: 100%;
    width: clamp(280px, 45vw, 850px);
    max-height: 85vh;
    object-fit: contain;
    mix-blend-mode: multiply;
    /* Ombre complexe pour incrustation réaliste */
    filter: drop-shadow(0 30px 40px rgba(0, 0, 0, 0.12)) 
            drop-shadow(0 10px 20px rgba(74, 93, 58, 0.15)) 
            drop-shadow(0 2px 5px rgba(181, 101, 29, 0.1));
    animation: float-subtle 5s ease-in-out infinite;
    transition: filter 0.3s ease;
  }

  .hero-3d__image-link:hover .hero-3d__image {
    filter: drop-shadow(0 35px 50px rgba(0, 0, 0, 0.15)) 
            drop-shadow(0 15px 25px rgba(74, 93, 58, 0.2)) 
            drop-shadow(0 5px 10px rgba(181, 101, 29, 0.15));
  }

  /* Indicateur de scroll */
  .hero-3d__scroll-indicator {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 90px;
    background-color: rgba(44, 44, 44, 0.15);
    z-index: 2;
    overflow: hidden;
  }

  @keyframes scroll-dot {
    0% { transform: translateY(-100%); opacity: 0; }
    20% { opacity: 1; }
    80% { opacity: 1; }
    100% { transform: translateY(90px); opacity: 0; }
  }

  .hero-3d__scroll-dot {
    width: 5px;
    height: 5px;
    background-color: var(--color-gold);
    border-radius: 50%;
    position: absolute;
    left: -2px;
    top: 0;
    animation: scroll-dot 2.5s cubic-bezier(0.65, 0, 0.35, 1) infinite;
  }
{% endstyle %}

<div class="hero-3d-{{ section.id }}">
  <!-- Filigrane de fond -->
  <div class="hero-3d__watermark" aria-hidden="true">
    {{ section.settings.watermark_text | default: shop.name }}
  </div>

  <!-- Colonne Texte -->
  <div class="hero-3d__content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="hero-3d__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h1 class="hero-3d__title">{{ section.settings.title | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="hero-3d__description">{{ section.settings.description }}</div>
    {%- endif -%}

    {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
      <a href="{{ section.settings.button_link }}" class="hero-3d__btn">
        {{ section.settings.button_label | escape }}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {%- endif -%}
  </div>

  <!-- Colonne Produit -->
  <div class="hero-3d__visual">
    {%- if section.settings.image_link != blank -%}
      <a href="{{ section.settings.image_link }}" class="hero-3d__image-link" aria-label="Voir la catégorie">
    {%- endif -%}
    
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1500 | image_tag: 
        class: 'hero-3d__image', 
        loading: 'eager', 
        alt: section.settings.image.alt | default: section.settings.title,
        widths: '300, 500, 750, 1000, 1500'
      }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'hero-3d__image' }}
    {%- endif -%}

    {%- if section.settings.image_link != blank -%}
      </a>
    {%- endif -%}
  </div>

  <!-- Indicateur de Scroll -->
  <div class="hero-3d__scroll-indicator" aria-hidden="true">
    <div class="hero-3d__scroll-dot"></div>
  </div>
</div>

{% schema %}
{
  "name": "Hero 3D Premium",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "watermark_text",
      "label": "Texte en filigrane (Arrière-plan)",
      "default": "Nuts Tree"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Surtitre",
      "default": "Fruits secs d'exception"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre principal",
      "default": "Le meilleur de la nature,\ntorréfié avec passion"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Sélection artisanale, du producteur à votre table. Découvrez nos créations exclusives.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte du bouton",
      "default": "Découvrir la boutique"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image du produit",
      "info": "Idéalement un produit sur fond transparent. L'effet multiply se chargera de l'incrustation."
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Lien de l'image",
      "info": "Rend l'image cliquable (ex: lien vers les catégories)."
    },
    {
      "type": "header",
      "content": "Couleurs (CSS Custom Properties)"
    },
    {
      "type": "color",
      "id": "color_primary",
      "label": "Primaire (Vert olive)",
      "default": "#4A5D3A"
    },
    {
      "type": "color",
      "id": "color_secondary",
      "label": "Secondaire (Terracotta)",
      "default": "#B5651D"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Fond (Crème)",
      "default": "#F5F0E6"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Texte (Quasi-noir)",
      "default": "#2C2C2C"
    },
    {
      "type": "color",
      "id": "color_surface",
      "label": "Surface (Blanc)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "color_gold",
      "label": "Doré",
      "default": "#C5A55A"
    }
  ],
  "presets": [
    {
      "name": "Hero 3D Premium",
      "category": "Image"
    }
  ]
}
{% endschema %}
