{% comment %}
  NUTSTREE — Grille Catégories Premium (Automatique)
  Lit TOUTES les collections Shopify automatiquement.
  Dès qu'une collection est ajoutée dans Admin → Produits → Collections,
  elle apparaît ici sans aucune configuration supplémentaire.
  
  Paramètres:
  - Exclure les collections "all" et "frontpage" (collections par défaut Dawn)
  - Limite configurable (default: 12)
  - Dégradés et icônes cycliques automatiques
{% endcomment %}

{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap');

  .nt-cats-{{ section.id }} {
    --c-primary: {{ section.settings.color_primary | default: '#3B4F2A' }};
    --c-text:    {{ section.settings.color_text    | default: '#2C2C2C' }};
    --c-bg:      {{ section.settings.color_background | default: '#F5F0E6' }};
    background-color: var(--c-bg);
    padding: 5rem 0 4rem;
  }

  .nt-cats__inner {
    padding: 0 1.25rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .nt-cats__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .nt-cats__title {
    font-family: 'Playfair Display', serif;
    font-weight: 600;
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    color: var(--c-primary);
    margin: 0;
  }

  .nt-cats__view-all {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: #C0622A;
    text-decoration: none;
    white-space: nowrap;
  }

  .nt-cats__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (min-width: 600px) {
    .nt-cats__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
  }

  @media (min-width: 990px) {
    .nt-cats__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop | default: 3 }}, 1fr);
      gap: 1.25rem;
    }
  }

  .nt-cat-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border-radius: 16px;
    height: 110px;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    padding: 12px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  @media (min-width: 768px) {
    .nt-cat-card {
      height: 150px;
    }
  }

  .nt-cat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 30px -14px rgba(0,0,0,.3);
  }

  /* Overlay gradient for text readability */
  .nt-cat-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(200deg, transparent 25%, rgba(0,0,0,.42));
    pointer-events: none;
    z-index: 1;
  }

  /* Real collection image */
  .nt-cat-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    z-index: 0;
  }

  .nt-cat-card:hover .nt-cat-card__img {
    transform: scale(1.08);
  }

  /* Gradient background (behind image, always visible as fallback) */
  .nt-cat-card__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* The 6 brand gradient palettes — cycle automatically */
  .nt-grad-0 { background: linear-gradient(135deg, #6B8A4A, #3B4F2A); }
  .nt-grad-1 { background: linear-gradient(135deg, #D9A94A, #C5A55A); }
  .nt-grad-2 { background: linear-gradient(135deg, #8B5A32, #5C3521); }
  .nt-grad-3 { background: linear-gradient(135deg, #D08055, #C0622A); }
  .nt-grad-4 { background: linear-gradient(135deg, #A68A55, #7A6339); }
  .nt-grad-5 { background: linear-gradient(135deg, #8B3E18, #5C2A0F); }

  .nt-cat-card__icon {
    position: relative;
    z-index: 2;
    color: rgba(255,255,255,.88);
    width: 20px;
    height: 20px;
    margin-bottom: 5px;
    flex-shrink: 0;
  }

  .nt-cat-card__name {
    position: relative;
    z-index: 2;
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 13px;
    line-height: 1.3;
    text-shadow: 0 1px 4px rgba(0,0,0,.25);
  }

  /* Product count badge */
  .nt-cat-card__count {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    background: rgba(255,255,255,.2);
    backdrop-filter: blur(4px);
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 600;
    padding: 3px 7px;
    border-radius: 20px;
  }

  /* Empty state */
  .nt-cats__empty {
    text-align: center;
    padding: 3rem;
    color: var(--c-text);
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    opacity: 0.6;
  }

  .nt-cats__footer {
    text-align: center;
    margin-top: 2rem;
  }

  .nt-cats__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 2.5rem;
    background: transparent;
    color: var(--c-primary);
    border: 1.5px solid var(--c-primary);
    border-radius: 50px;
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
    cursor: pointer;
  }

  .nt-cats__btn:hover {
    background: var(--c-primary);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(59,79,42,.2);
  }
{%- endstyle -%}

{%- comment -%}
  Icônes thématiques : on essaie de deviner l'icône depuis le handle de la collection.
  Si aucune correspondance, on cycle sur 6 icônes génériques.
{%- endcomment -%}

{%- liquid
  assign icon_handles = 'fruit,sec,olive,amande,pistache,noix,cajou,noisette|miel,honey,api|chocolat,choco,cacao|confit,cerise,abricot|epice,cannelle,cumin,safran,curcuma|cadeau,coffret,gift,plateau|datte,medjool,ajwa,sukkari|amlou,the,tisane' | split: '|'
  assign icon_names   = 'leaf|honey|chocolate|fruit|spice|gift|dates|leaf' | split: '|'
-%}

<div class="nt-cats-{{ section.id }}">
  <div class="nt-cats__inner">

    {%- if section.settings.title != blank -%}
      <div class="nt-cats__header">
        <h2 class="nt-cats__title">{{ section.settings.title | escape }}</h2>
        {%- if section.settings.show_view_all -%}
          <a href="/collections" class="nt-cats__view-all">Tout voir →</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Collect real collections, excluding defaults {%- endcomment -%}
    {%- liquid
      assign display_limit = section.settings.max_collections | default: 12
      assign shown = 0
      assign col_list = ''
    -%}

    {%- comment -%} Build list of valid collections first {%- endcomment -%}
    {%- assign valid_collections = '' -%}
    {%- for coll in collections -%}
      {%- if coll.handle == 'all' or coll.handle == 'frontpage' -%}
        {%- continue -%}
      {%- endif -%}
      {%- if shown < display_limit -%}
        {%- assign shown = shown | plus: 1 -%}
        {%- unless forloop.first -%}{%- endunless -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if shown == 0 -%}
      <p class="nt-cats__empty">Aucune collection trouvée — créez vos collections dans <strong>Admin → Produits → Collections</strong>.</p>
    {%- else -%}
      <ul class="nt-cats__grid">
        {%- assign loop_index = 0 -%}
        {%- for coll in collections -%}
          {%- if coll.handle == 'all' or coll.handle == 'frontpage' -%}
            {%- continue -%}
          {%- endif -%}
          {%- if loop_index >= display_limit -%}
            {%- break -%}
          {%- endif -%}

          {%- comment -%} Auto gradient (cycles 0-5) {%- endcomment -%}
          {%- assign grad_index = loop_index | modulo: 6 -%}

          {%- comment -%} Auto icon guess from handle {%- endcomment -%}
          {%- assign icon_id = 'leaf' -%}
          {%- for pattern_group in icon_handles -%}
            {%- assign patterns = pattern_group | split: ',' -%}
            {%- for pat in patterns -%}
              {%- if coll.handle contains pat -%}
                {%- assign icon_id = icon_names[forloop.parentloop.index0] -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endfor -%}

          <li>
            <a href="{{ coll.url }}" class="nt-cat-card">

              {%- comment -%} Gradient fallback {%- endcomment -%}
              <div class="nt-cat-card__bg nt-grad-{{ grad_index }}"></div>

              {%- comment -%} Real collection image {%- endcomment -%}
              {%- if coll.image -%}
                <img
                  src="{{ coll.image | image_url: width: 600 }}"
                  alt="{{ coll.title | escape }}"
                  class="nt-cat-card__img"
                  loading="lazy"
                  width="600"
                  height="300"
                >
              {%- elsif coll.products.first.featured_image -%}
                <img
                  src="{{ coll.products.first.featured_image | image_url: width: 600 }}"
                  alt="{{ coll.title | escape }}"
                  class="nt-cat-card__img"
                  loading="lazy"
                  width="600"
                  height="300"
                >
              {%- endif -%}

              {%- comment -%} Product count badge {%- endcomment -%}
              {%- if section.settings.show_count and coll.products_count > 0 -%}
                <div class="nt-cat-card__count">{{ coll.products_count }} produits</div>
              {%- endif -%}

              {%- comment -%} Thematic SVG icon {%- endcomment -%}
              <div class="nt-cat-card__icon" aria-hidden="true">
                {%- case icon_id -%}
                  {%- when 'honey' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10c4-4 12-4 16 0M6 14c3-3 9-3 12 0M9 18c1.5-1.5 4.5-1.5 6 0"/></svg>
                  {%- when 'chocolate' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18M9 5v14M15 5v14"/></svg>
                  {%- when 'fruit' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="13" r="7"/><path d="M12 6V3m-3 3c0-1.7 1.3-3 3-3s3 1.3 3 3"/></svg>
                  {%- when 'spice' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v10M8 7l4-4 4 4M6 13h12l-1.5 8h-9z"/></svg>
                  {%- when 'gift' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12v9H4v-9M2 7h20v5H2zM12 7V3M12 7c-2 0-3.5-2-2-4 2-1 2.5 1.5 2 4zM12 7c2 0 3.5-2 2-4-2-1-2.5 1.5-2 4z"/></svg>
                  {%- when 'dates' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="14" rx="5" ry="7"/><path d="M12 7V3M9 5c0 0 1-2 3-2s3 2 3 2"/></svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8 6 6 9 6 13a6 6 0 0012 0c0-4-2-7-6-11z"/><path d="M12 22v-9"/></svg>
                {%- endcase -%}
              </div>

              <span class="nt-cat-card__name">{{ coll.title }}</span>

            </a>
          </li>

          {%- assign loop_index = loop_index | plus: 1 -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.show_view_all and section.settings.btn_text != blank -%}
      <div class="nt-cats__footer">
        <a href="/collections" class="nt-cats__btn">{{ section.settings.btn_text | escape }}</a>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Catégories (Auto)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "✅ Cette section affiche automatiquement toutes vos collections Shopify. Ajoutez une collection dans Admin → Produits → Collections et elle apparaît ici instantanément."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre de la section",
      "default": "Nos univers"
    },
    {
      "type": "range",
      "id": "max_collections",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 12,
      "label": "Nombre maximum de catégories affichées"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Colonnes sur ordinateur"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Afficher le nombre de produits par catégorie",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Afficher le bouton 'Tout voir'",
      "default": true
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Texte du bouton",
      "default": "Voir toutes les catégories"
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "color_primary",
      "label": "Titre",
      "default": "#3B4F2A"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Fond de section",
      "default": "#F5F0E6"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Texte",
      "default": "#2C2C2C"
    }
  ],
  "presets": [
    {
      "name": "Catégories (Auto)"
    }
  ]
}
{% endschema %}
