{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@600;700;900&display=swap');

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-hero-{{ section.id }} {
    /* Intégration de nos couleurs personnalisées avec fallback sur les settings */
    --color-primary: {{ section.settings.color_primary }};
    --color-background: {{ section.settings.color_background }};
    --font-heading-family: 'Playfair Display', serif;
    --font-body-family: 'Inter', sans-serif;
    
    background-color: var(--color-background);
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    min-height: 80vh; /* Premium feel with generous height */
  }

  /* Filigrane arrière-plan */
  .custom-hero__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-heading-family);
    font-size: clamp(10rem, 25vw, 40rem);
    font-weight: 900;
    color: #2C2C2C;
    opacity: 0.03;
    white-space: nowrap;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }

  /* Grille Responsive (Mobile first) */
  .custom-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  @media screen and (min-width: 990px) {
    .custom-hero__grid {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }
  }

  .custom-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  .custom-hero__eyebrow {
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-primary);
    margin-bottom: 2rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .custom-hero__eyebrow::before {
    content: '';
    display: block;
    width: 50px;
    height: 1px;
    background-color: var(--color-primary);
  }

  .custom-hero__title {
    font-family: var(--font-heading-family);
    font-size: clamp(4rem, 6vw + 1rem, 7rem);
    line-height: 1.1;
    color: #2C2C2C;
    margin: 0 0 2rem 0;
    font-weight: 700;
  }

  .custom-hero__text {
    font-family: var(--font-body-family);
    font-size: clamp(1.4rem, 1.5vw + 0.5rem, 1.8rem);
    line-height: 1.6;
    color: rgba(44, 44, 44, 0.8);
    margin-bottom: 4rem;
    max-width: 48rem;
  }

  .custom-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 4.8rem;
    padding: 1.5rem 4rem;
    background-color: var(--color-primary);
    color: #FFFFFF;
    font-family: var(--font-body-family);
    font-size: 1.5rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 4px;
    transition: background-color 0.3s ease, transform 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .custom-hero__button:hover {
    background-color: #3a4a2e; /* Vert olive assombri pour le hover */
    transform: translateY(-2px);
  }

  .custom-hero__button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
    box-shadow: none;
  }

  /* Média & Produit Lévitant */
  .custom-hero__media {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .custom-hero__image {
    max-width: 100%;
    height: auto;
    width: clamp(280px, 45vw, 750px);
    /* Le mix-blend-mode parfait pour les fonds clairs */
    mix-blend-mode: multiply;
    /* Ombre portée complexe pour un rendu 3D premium */
    filter: drop-shadow(0 25px 35px rgba(0, 0, 0, 0.1)) drop-shadow(0 10px 15px rgba(74, 93, 58, 0.15));
    animation: customHeroFloat 6s ease-in-out infinite;
  }

  @keyframes customHeroFloat {
    0% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(1deg); }
    100% { transform: translateY(0px) rotate(0deg); }
  }
{%- endstyle -%}

<div class="custom-hero-{{ section.id }} section-{{ section.id }}-padding">
  
  {%- if section.settings.watermark_text != blank -%}
    <div class="custom-hero__watermark" aria-hidden="true">
      {{ section.settings.watermark_text }}
    </div>
  {%- endif -%}

  <!-- Utilisation de la classe utilitaire native de Dawn 'page-width' pour l'alignement -->
  <div class="page-width">
    <div class="custom-hero__grid">
      
      <!-- Colonne Contenu -->
      <div class="custom-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <div class="custom-hero__eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h1 class="custom-hero__title">{{ section.settings.title | newline_to_br }}</h1>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="custom-hero__text">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a {% if section.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ section.settings.button_link }}"{% endif %} class="custom-hero__button">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>

      <!-- Colonne Image -->
      <div class="custom-hero__media">
        {%- if section.settings.image != blank -%}
          {%- assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio -%}
          {{ section.settings.image | image_url: width: 1500 | image_tag:
            loading: 'eager',
            width: section.settings.image.width,
            height: image_height,
            class: 'custom-hero__image',
            sizes: '(min-width: 990px) 50vw, 100vw',
            widths: '375, 550, 750, 1100, 1500'
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'custom-hero__image placeholder-svg' }}
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Premium - Nutstree",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "watermark_text",
      "label": "Texte en filigrane (Arrière-plan)",
      "default": "Nutstree"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Surtitre",
      "default": "Spécialité Artisanale"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre principal",
      "default": "Amandes enrobées\nde poudre de chia"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte de description",
      "default": "<p>Découvrez notre création signature. Le croquant de l'amande torréfiée marié à l'intensité de la poudre de chia, pour une expérience gustative inoubliable.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Texte du bouton",
      "default": "Déguster maintenant"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image du produit",
      "info": "Image sur fond blanc recommandée. Le mix-blend-mode s'occupera du détourage parfait."
    },
    {
      "type": "header",
      "content": "Design System (Couleurs)"
    },
    {
      "type": "color",
      "id": "color_primary",
      "label": "Couleur Primaire (Vert Olive)",
      "default": "#4A5D3A"
    },
    {
      "type": "color",
      "id": "color_background",
      "label": "Couleur de Fond (Crème)",
      "default": "#F5F0E6"
    },
    {
      "type": "header",
      "content": "Espacements (Padding Dawn)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Espacement Haut",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Espacement Bas",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Hero Premium - Nutstree",
      "category": "Image"
    }
  ]
}
{% endschema %}
